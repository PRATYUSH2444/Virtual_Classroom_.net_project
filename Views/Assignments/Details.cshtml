@model VirtualClassroom2.Models.Assignment

@{
    ViewData["Title"] = "Assignment Details";
}

<div class="container">
    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header">
                    <h4 class="mb-0">Assignment Details</h4>
                </div>
                <div class="card-body">
                    <h3>@Model.Title</h3>
                    <div class="assignment-meta mb-3">
                        <span class="badge bg-primary">@Model.Points Points</span>
                        <span class="badge @(Model.DueDate < DateTime.Now ? "bg-warning" : "bg-success")">
                            Due: @Model.DueDate.ToString("MMM dd, yyyy HH:mm")
                        </span>
                        @if (Model.DueDate < DateTime.Now)
                        {
                            <span class="badge bg-danger">Overdue</span>
                        }
                    </div>

                    <h5>Instructions:</h5>
                    <div class="bg-light p-3 rounded mb-3">
                        @Model.Instructions
                    </div>

                    <div class="assignment-info">
                        <p><strong>Classroom:</strong> @Model.Classroom.Title</p>
                        <p><strong>Created By:</strong> @Model.CreatedBy.FirstName @Model.CreatedBy.LastName</p>
                        <p><strong>Created Date:</strong> @Model.CreatedAt.ToString("MMM dd, yyyy")</p>
                    </div>

                    <div class="mt-4">
                        @if (User.IsInRole("Student"))
                        {
                            <a href="@Url.Action("Submit", new { id = Model.Id })" class="btn btn-success">
                                <i class="fas fa-paper-plane"></i>
                                @(ViewBag.HasSubmitted ? "Update Submission" : "Submit Assignment")
                            </a>
                        }
                        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Back to List</a>

                        @if ((User.IsInRole("Teacher") && Model.CreatedById == ViewBag.CurrentUserId) || User.IsInRole("Admin"))
                        {
                            <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-outline-primary">Edit</a>
                            <a href="@Url.Action("Delete", new { id = Model.Id })" class="btn btn-outline-danger">Delete</a>
                        }
                    </div>
                </div>
            </div>

            @if ((User.IsInRole("Teacher") && Model.CreatedById == ViewBag.CurrentUserId) || User.IsInRole("Admin"))
            {
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="fas fa-users me-2"></i>
                            Submissions (@Model.Submissions.Count)
                        </h5>
                    </div>
                    <div class="card-body">
                        @if (Model.Submissions.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-striped">
                                    <thead>
                                        <tr>
                                            <th>Student</th>
                                            <th>Submitted</th>
                                            <th>Status</th>
                                            <th>Marks</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var submission in Model.Submissions)
                                        {
                                            <tr>
                                                <td>@submission.Student.FirstName @submission.Student.LastName</td>
                                                <td>
                                                    @submission.SubmittedAt.ToString("MMM dd, yyyy HH:mm")
                                                    @if (submission.SubmittedAt > Model.DueDate)
                                                    {
                                                        <br>
                                        
                                                        <span class="badge bg-warning">Late</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (submission.Marks.HasValue)
                                                    {
                                                        <span class="badge bg-success">Graded</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-warning">Pending</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (submission.Marks.HasValue)
                                                    {
                                                        <span class="badge bg-success">@submission.Marks/@Model.Points</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">-</span>
                                                    }
                                                </td>
                                                <td>
                                                    <a href="@Url.Action("DownloadSubmission", new { id = submission.Id })" class="btn btn-sm btn-outline-primary">
                                                        <i class="fas fa-download"></i> Download
                                                    </a>
                                                    <button type="button" class="btn btn-sm btn-outline-info"
                                                            data-bs-toggle="modal" data-bs-target="#gradeModal@(submission.Id)">
                                                        <i class="fas fa-edit"></i> Grade
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted">No submissions yet.</p>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Grade Modals -->
@if ((User.IsInRole("Teacher") && Model.CreatedById == ViewBag.CurrentUserId) || User.IsInRole("Admin"))
{
    @foreach (var submission in Model.Submissions)
    {
        <div class="modal fade" id="gradeModal@(submission.Id)" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Grade Submission - @submission.Student.FirstName @submission.Student.LastName</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <form asp-action="Grade" method="post">
                        <input type="hidden" name="submissionId" value="@submission.Id" />
                        <div class="modal-body">
                            <div class="form-group mb-3">
                                <label>Marks (out of @Model.Points)</label>
                                <input type="number" name="marks" class="form-control" min="0" max="@Model.Points"
                                       value="@(submission.Marks ?? 0)" step="0.5" required />
                            </div>
                            <div class="form-group">
                                <label>Feedback</label>
                                <textarea name="feedback" class="form-control" rows="3" placeholder="Provide feedback to student...">@submission.Feedback</textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Save Grade</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}